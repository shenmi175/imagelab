NODE_ENV=production
APP_URL=http://localhost:3005
TRUST_PROXY=true
SESSION_SECRET=change-this-to-a-long-random-secret
SESSION_COOKIE_NAME=image_site_session
SESSION_TTL_DAYS=14
BUSINESS_TIME_ZONE=Asia/Hong_Kong

NODE_IMAGE=node:22-bookworm-slim
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
NPM_REGISTRY=https://registry.npmjs.org/

POSTGRES_PASSWORD=image_app_password
DATABASE_URL=postgresql://image_app:image_app_password@postgres:5432/image_app
REDIS_URL=redis://redis:6379
QUEUE_NAME=image-generation
QUEUE_BOARD_PORT=3001
QUEUE_BOARD_PUBLIC_PORT=3006
QUEUE_BOARD_BASE_PATH=/admin/queues
QUEUE_BOARD_USERNAME=admin
QUEUE_BOARD_PASSWORD=change-me-before-deploy
QUEUE_BOARD_PUBLIC_URL=http://localhost:3006/admin/queues

SUB2API_BASE_URL=http://host.docker.internal:8080
SUB2API_API_KEY=sk-change-me
IMAGE_MODEL=gpt-image-2
UPSTREAM_TIMEOUT_SECONDS=900

DEFAULT_IMAGE_SIZE=1024x1024
DEFAULT_IMAGE_QUALITY=high
DEFAULT_IMAGE_FORMAT=png
DEFAULT_IMAGE_BACKGROUND=auto
DEFAULT_IMAGE_MODERATION=auto
MAX_PROMPT_LENGTH=2000
UPSTREAM_INPUT_IMAGE_MAX_BYTES=1200000
UPSTREAM_INPUT_IMAGES_TOTAL_MAX_BYTES=4000000
UPSTREAM_INPUT_IMAGE_MAX_EDGE=1536
UPSTREAM_INPUT_IMAGE_QUALITY=84

MAX_GLOBAL_CONCURRENCY=2
MAX_QUEUE_LENGTH=50
MAX_USER_ACTIVE_JOBS=1
MAX_JOB_ATTEMPTS=2
JOB_LOCK_SECONDS=900
RUNNING_JOB_STALE_SECONDS=180
WORKER_ORPHANED_RUNNING_GRACE_SECONDS=120
WORKER_HEARTBEAT_TTL_SECONDS=90
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_STOP_GRACE_PERIOD=20m
OUTBOX_DISPATCH_INTERVAL_SECONDS=10
RECONCILE_INTERVAL_SECONDS=30

DEFAULT_DAILY_QUOTA=3
ADMIN_BYPASS_DAILY_QUOTA=true

RATE_LIMIT_REGISTER_IP_HOUR=3
RATE_LIMIT_LOGIN_IP_MINUTE=10
RATE_LIMIT_LOGIN_EMAIL_HOUR=20
RATE_LIMIT_CREATE_JOB_USER_MINUTE=3
RATE_LIMIT_FEEDBACK_USER_HOUR=10
RATE_LIMIT_POLL_USER_MINUTE=60

IMAGE_STORAGE_DIR=/app/storage/generated
IMAGE_RETENTION_DAYS=3

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-deploy
ADMIN_RESET_PASSWORD=false

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
